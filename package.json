{
  "name": "hexbench",
  "version": "1.0.0",
  "description": "Hexbench — a honeycomb workbench for your clipboard, notes, and text tools",
  "main": "src/main/main.js",
  "author": "Dawid Polakowski",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "icons": "node scripts/generate-icons.js",
    "lint": "eslint src/ scripts/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^9.39.4",
    "globals": "^15.0.0"
  },
  "build": {
    "appId": "com.dawidpolakowski.hexbench",
    "productName": "Hexbench",
    "publish": {
      "provider": "github",
      "owner": "dawidpolakowski",
      "repo": "hexClipboard"
    },
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/renderer/**/*",
      "src/utils/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
